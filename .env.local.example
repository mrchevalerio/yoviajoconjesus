# Copy to .env.local and fill in real keys before going live.
# Until these are set, the app runs fully in demo/sandbox mode —
# payment is simulated.

# Stripe (test key first: https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Booking confirmation email (https://resend.com/api-keys). Without this,
# the booking flow still works, it just skips sending the email.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Address autocomplete: optional. Without either of these, the app already
# works using OpenStreetMap Nominatim (free, no key) — set one of these for
# faster/more polished results in production.
MAPBOX_ACCESS_TOKEN=
GOOGLE_PLACES_API_KEY=

# Supabase (trip request form). Required — src/lib/supabase.ts throws at
# import time if either is missing.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase service role key (Project Settings -> API Keys -> service_role).
# Server-only — never expose with a NEXT_PUBLIC_ prefix. Used by
# src/lib/supabaseAdmin.ts to write confirmed bookings after independently
# verifying payment with Stripe, bypassing the anon role's RLS restrictions.
SUPABASE_SERVICE_ROLE_KEY=
